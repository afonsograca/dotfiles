function xctoggle() {
    RELEASE="Xcode.app"
    BETA="Xcode-beta.app"

    CURRENT=$(xcode-select -p)
    NEXT=""

    if [[ "$CURRENT" =~ "$RELEASE" ]]
    then
        NEXT="$BETA"
    else
        NEXT="$RELEASE"
    fi

#https://www.smileykeith.com/2021/08/12/xcode-select-sudoers/
    sudo xcode-select -s "/Applications/$NEXT"
    echo "Switched to $NEXT"
}