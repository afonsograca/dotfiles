##

## Zsh shell options configuration

##

# Editor mode

setopt emacs # Use emacs-style key bindings

# Globbing

setopt NO_CASE_GLOB      # Case insensitive globbing
setopt GLOB_COMPLETE     # Show ambiguous globs as menu
setopt NUMERIC_GLOB_SORT # Sort globs numerically when possible

# History

HISTFILE=${ZDOTDIR}/.zsh_history # History file location
SAVEHIST=20000                   # Number of lines to save to history file
HISTSIZE=50000                   # Number of lines to keep in memory
setopt EXTENDED_HISTORY          # Save timestamp and duration with each command
setopt INC_APPEND_HISTORY_TIME   # Append to history file immediately with timestamps
setopt HIST_EXPIRE_DUPS_FIRST    # Expire duplicate entries first when trimming history
setopt HIST_IGNORE_DUPS          # Don't record duplicate consecutive entries
setopt HIST_FIND_NO_DUPS         # Don't display duplicates when searching history
setopt HIST_REDUCE_BLANKS        # Remove extra blanks from commands before adding to history
setopt HIST_IGNORE_SPACE         # Don't record commands that start with a space

# Enhanced history search

autoload -U up-line-or-beginning-search
autoload -U down-line-or-beginning-search
zle -N up-line-or-beginning-search
zle -N down-line-or-beginning-search
bindkey "^[[A" up-line-or-beginning-search   # Up arrow key
bindkey "^[[B" down-line-or-beginning-search # Down arrow key

# Command correction

setopt CORRECT     # Try to correct spelling of commands
setopt CORRECT_ALL # Try to correct spelling of all arguments

# Tab completion

zstyle ':completion:*' matcher-list \
  'm:{[:lower:][:upper:]}={[:upper:][:lower:]}' \
  'm:{[:lower:][:upper:]}={[:upper:][:lower:]} l:|=* r:|=*' \
  'm:{[:lower:][:upper:]}={[:upper:][:lower:]} l:|=* r:|=*' \
  'm:{[:lower:][:upper:]}={[:upper:][:lower:]} l:|=* r:|=*'
zstyle ':completion:*' list-colors ''   # Use default colors for completion menu
zstyle ':completion:*' insert-tab false # Don't insert tab when no completions
autoload -Uz compinit && compinit       # Load and initialize completion system

# Directory navigation
setopt PUSHD_IGNORE_DUPS # Don't push multiple copies of the same directory

# Job control

setopt NO_HUP        # Don't send HUP signal to background jobs when shell exits
setopt NO_CHECK_JOBS # Don't warn about running jobs when exiting

# Input/Output

setopt INTERACTIVE_COMMENTS # Allow comments in interactive shells
setopt PRINT_EXIT_VALUE     # Print the exit value of programs with non-zero exit status

# Expansion

setopt EXTENDED_GLOB # Use extended globbing syntax
setopt GLOB_DOTS     # Include dotfiles in glob patterns

# Performance

setopt HASH_CMDS # Hash commands as they are executed
setopt HASH_DIRS # Hash directories as they are used

# Safety

setopt NO_CLOBBER # Don't overwrite existing files with > redirection
setopt IGNORE_EOF # Don't exit on EOF (Ctrl-D)
