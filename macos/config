#     "Dock" \
#     "Finder" \
  #   "Google Chrome Canary" \
  #   "Google Chrome" \
  #   "Mail" \
  #   "Messages" \
  #   "Opera" \
  #   "Photos" \
  #   "Safari" \
  #   "SizeUp" \
  #   "Spectacle" \
#     "SystemUIServer" \
  #   "Terminal" \
  #   "Transmission" \
  #   "Tweetbot" \
  #   "Twitter" \
  #   "iCal"; do
  #   killall "${app}" &> /dev/null
  # done


  print_header_footer "Step: System — DONE! (Note: some of these changes require a logout/restart to take effect.)"
}

