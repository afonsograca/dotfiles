handle_macos_configs() {
  
  ### Includes
  if test -z "${base_dir+empty}"; then
    local base_dir="$(cd "$(dirname "$0")/.."; pwd)"
  fi
  local macos_dir="$base_dir/macos"
  
  if ! command -v source_files_in >/dev/null 2>&1; then
    source "$base_dir/bin/source_files_in.sh"
  fi
  
  if ! command -v activate_sudo >/dev/null 2>&1; then
    source "$base_dir/bin/sudo.sh"
  fi
  
  if ! command -v print_header_footer >/dev/null 2>&1; then
    source "$base_dir/bin/print_utils.sh"
  fi
  
  ### Intro
  print_header_footer "Step: macOS" $1


  ### Pre-script sanity checks 

  # Prevent overrides by closing all System Prefs
  osascript -e 'tell application "System Preferences" to quit'

  # Make sure you have admin privileges
  activate_sudo


  ### General
  handle_general_config

  ### Desktop & Screen Saver
  handle_desktop_and_screen_saver_config

  ### Dock
  handle_dock_config
  

  ### Security & Privacy
  handle_security_and_privacy_config

  ### Displays
  handle_display_config

  ### Energy Saver
  handle_energy_saver_config

  ### Keyboard
