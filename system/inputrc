##
## Readline configuration script
##

## Blink on matchin parenthesis
set blink-matching-paren on

## Display color of possible completions by file-type
set colored-stats on
set colored-completion-prefix on

## Perform filename matching and completion in a case-insensitive fashion
set completion-ignore-case on

## Treat hyphens (‘-’) and underscores (‘_’) as equivalent 
## when performing case-insensitive filename matching and completion.
set completion-map-case on

## UTF8 support
set convert-meta off # do not strip the 8th bit
set input-meta on
set output-meta on

## Append slash to symlinked directories
set mark-symlinked-directories on

## Prevent matching with hidden files without explicit .
set match-hidden-files off 

## Display all results at once
set page-completions off

## List ambiguous matches immediately
set show-all-if-ambiguous on

## Do not duplicate portions of words when performing
## completion in the middle of the word.
set skip-completed-text on

$if mode=emacs

  ## Bind up and down cursor keys to incrementally search history
  "\e[A": history-search-backward
  "\e[B": history-search-forward
  "\e[C": forward-char
  "\e[D": backward-char

$endif
