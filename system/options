##
## Shell options configuration
##

### Enable auto cd by directory name, if available
shopt -s autocd 2> /dev/null


### Correct typos in a directory component in a cd command 
shopt -s cdspell


### Update LINES and COLUMNS with each command - window size change
shopt -s checkwinsize


### Enable recursive globbing, if available
shopt -s globstar 2> /dev/null


# Append to the Bash history file, rather than overwriting it
shopt -s histappend


### Enable hostname completion
shopt -s hostcomplete


### Disable tab-completion on empty an empty entry
shopt -s no_empty_cmd_completion


### Enable case-insensitive globbing
shopt -s nocaseglob
