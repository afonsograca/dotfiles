  followTags = false # push tags simulatenously with commits
  gpgSign = if-asked # sign push if necessary
  # pushOption # options to be passed to the server (pre & post receive hook)
  recurseSubmodules = check # check if all submodule commits are available remote

[rebase]
  abbreviateCommands = false # while interactive rebasing should print p instead of pick (abbreviate commands)
  autoSquash = true # reorder commits marked with fixup and squash during rebases
  autoStash = true # stash uncommited changes before rebasing
  instructionFormat = oneline # the format used for the list of commits during an interactive rebase
  missingCommitsCheck = warn # check if commits were removed during rebase (default: ignore) 
  stat = true # show diffstat of the changes of the rebase

