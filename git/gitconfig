[column]
  ui = auto column nodense # should output in columns (default never column nodense)
  # branch # specify column behaviour on `git branch`. Overrides `ui`.
  # clean # specify column behaviour on `git clean -i`. Overrides `ui`.
  # status # specify column behaviour on `git status`. Overrides `ui`.
  # tag # specify column behaviour on `git tag`. Overrides `ui`.

[commit]
  cleanup = default # clean whitespaces and comments from messages
  gpgSign = true # sign all commits
  status = true # show commit status in message editor as a comment
  # template = ~/.gitmessage # path to template to be used in the commit message
  verbose = true # show diff as a comment in the message editor

[core]
  abbrev = auto # length to which object names are abbreviated to
  # askPass # set commands to ask for user/pass (default unset)
  attributesFile = ~/.gitattributes # global attributes file
  autocrlf = input # properly handle line endings
  # bare # not applicable to a global gitconfig, relates to repo type
  # bigFileThreshold # threshold upon which files are stored deflated
  checkStat = default # determines which stat fields to match
  commentChar = "#" # character to mark a comment (default #)
  # compression = # takes a value 0..9, being 0 no compression and 9 best compression of objects
  # createObject # determine how files are created depending on the sytem/OS combinations (default unset)
  # deltaBaseCacheLimit # Max nº of bytes to reserve for caching base objects
  editor = "vim" # editor to be used by `git commit` and `git tag`
  eol = native # line ending type to use (default native)
  excludesFile = ~/.gitignore_global # global ignore file
  fileMode = true # honour the executable bit of the file mode (default true)
  # filesRefLockTimeout # time to wait until retry locking a ref (default 100 ms)
  # fsmonitor # command to track changed files since a specified time
  fsync = all # enable fsync() when writing object files (default false)
  # gitProxy # set a proxy command for git protocol
  hideDotFiles = dotGitOnly # Windows only - mark . files/folders as hidden (default dotGitOnly)
  hooksPath = ~/.githooks # global hooks directory
  ignoreCase = false # workarounds for case-insensitive filesystems
  ignoreStat = false # ignore stat of possible changed files (default false)
  # logAllRefUpdates # not applicable to a global gitconfig, relates to reflog
  # looseCompression # same as compression but for objects not in a pack file (default 1)
  # notesRef # path to notes when `git show --notes` (default refs/notes/commits)
  # packedGitLimit # Max nº of bytes to map simultaneously into memory
  # packedGitWindowSize # nº of bytes/pack-file to map into memory
  # packedRefsTimeout # time to wait until retry locking a packed ref (default 1000)
  pager = less -M # text viewer for use by Git commands like `diff`
  precomposeUnicode = true # prevent showing unicode filenames as untracked
  preferSymlinkRefs = false # prefer symlink refs instead of default symrefs
  preloadIndex = true # enable parallel index preload (default true)
  # protectHFS # protect `.git` paths on HFS -- better left unset
  # protectNTFS # prevent problematic paths on NTFS -- better left unset
  quotePath = false # prevent escaping unicode characters
  # repositoryFormatVersion # not applicable to a global gitconfig, relates to repo's format and layout version
  safecrlf = true # check if converting CRLF is reversible
  # sharedRepository # not applicable to a global gitconfig, relates to repo read/write abilities
  # sparseCheckout # applicable on a repo basis, only to checkout parts of the repo
  splitIndex = false # don't use the split-index feature
  # sshCommand # set a proxy command to use instead of ssh
  symlinks = true # support symlinks (default true)
  trustctime = false # ignore ctime differences
  untrackedCache = true # way to speed up commands that involve determining untracked files
  warnAmbiguousRefs = true # warn about ambiguous ref names (default true)
  whitespace = space-before-tab,trailing-space # list of common whitespace problems to notice
  # worktree # not applicable to a global gitconfig, relates to repo

[credential]
	helper = osxkeychain # use macOS keychain as a helper to handle credentials
  useHttpPath = true # consider the "path" component of an URL to require different credentials

[credentialCache]
  ignoreSIGHUP = true # ignore SIGHUP, instead of quitting

