##
## User-level Git Configuration file
##

[add]
  ignoreErrors = true # make `git add` error not fatal

[advice]
  addEmbeddedRepo = true # advice on accidental repo nesting
  amWorkDir = true # show location of patch when `git am` fails
  commitBeforeMerge = true # advice on merge failure due to uncommitted changes
  detachedHead = true  # advice how to create branch when in detach HEAD state
  ignoredHook = true # warn about ignored hook because it is not set as executable
  implicitIdentity = true # advice on how to set identity when none is set 
  pushAlreadyExists = true # advice on bad push for not being able to Fast-Forward
  pushFetchFirst = true # advice to fetch when trying to push to a branch ahead
  pushNeedsForce = true # advice on how to force a push to be accepted 
  pushNonFFCurrent = true # hints when push fails due to a non-fast-forward update 
  pushNonFFMatching = true # hints when matching push fails due to a NFF update
  pushUpdateRejected = true  # turn all push* advices on/off simultaneously
  resolveConflict = true # command advice on how to resolve conflicts 
  rmHints = true # hints when `git rm` fails
  statusHints = true # hints on how to deal with files on `git status`
  statusUoption = true # advice to use `-u` option when `git status` is slow
  waitingForEditor = true  # message while waiting for editor input from the user

[alias]
  hist = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short
 
[am]
  keepcr = true # not remove \\r from lines ending with \\r\\n
  threeWay = true # fall back on 3-way merge if the patch does not apply cleanly

[apply]
  ignoreWhitespace = change # ignore changes in whitespace
  whitespace = fix # fix whitespace issues automatically

[blame]
  showRoot = false # mark root commit with a ^ before the hash
  blankBoundary = true # present a blank hash for boundary commits
  showEmail = true # show the author's email instead of the name  
  # date # the format of the date shown (default unset - ISO)

[branch]
  autoSetupMerge = true # should `git branch`/`git checkout` imply the `--track` option (default true)
  autoSetupRebase = always # should new branches should be set up to be rebased upon `git pull` (default never)

# [browser "command_name"]
  # cmd # command executed by the shell
  # path # override path for tool

[clean]
  requireForce = true # make `git-clean` do nothing unless given -f, -i or -n

[color]
  # branch # colour in `git branch`. Overrides `ui` value (default auto)
  # diff # ANSI escape sequences in patches. Overrides `ui` value (default auto)
  # grep # colour matches. Overrides `ui` value (default auto)
  # interactive # colour interactive prompts. Overrides `ui` value (default auto)
  pager = true # colour when using pager (default true)
  # showBranch # colour in `git show`. Overrides `ui` value (default auto)
  # status # colour in `git status`. Overrides `ui` value (default auto)
  ui = auto # default colour mode for all the color options
  
