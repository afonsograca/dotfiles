##
## Zsh profile configurations (loaded before zshrc for login shells)
##

# Load Apple Terminal integration if available
[[ -r /etc/zshrc_Apple_Terminal ]] && source /etc/zshrc_Apple_Terminal

# Load source_if_missing utility first
if [[ -f "$DOTFILES_PATH/bin/source_if_missing.sh" ]]; then
  source "$DOTFILES_PATH/bin/source_if_missing.sh"
fi

# Load utilities using source_if_missing
source_if_missing source_files_in "$DOTFILES_PATH/bin/source_files_in.sh"

# Set up PATH from various sources
# Note: In production, these will be inlined by the build process
[[ -f "$DOTFILES_PATH/packages/homebrew/path" ]] && source "$DOTFILES_PATH/packages/homebrew/path"
[[ -f "$DOTFILES_PATH/environments/mise/path" ]] && source "$DOTFILES_PATH/environments/mise/path"
[[ -f "$DOTFILES_PATH/environments/path" ]] && source "$DOTFILES_PATH/environments/path"
[[ -f "$DOTFILES_PATH/apps/vscode/path" ]] && source "$DOTFILES_PATH/apps/vscode/path"
[[ -f "$DOTFILES_PATH/ssh/path" ]] && source "$DOTFILES_PATH/ssh/path"

# Load local customizations
source_files_in "$DOTFILES_PATH/extra/**/*zsh*profile*"
