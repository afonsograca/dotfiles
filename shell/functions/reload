##
## Reload shell configuration
##

reload() {
  local -a config_files

  if [[ -n "$ZSH_VERSION" ]]; then
    config_files=(
      "$HOME/.zshenv"
      "${ZDOTDIR:-$HOME/.zsh}/.zprofile"
      "${ZDOTDIR:-$HOME/.zsh}/.zshrc"
    )
  else
    config_files=(
      "$HOME/.bash_profile"
      "$HOME/.bashrc"
    )
  fi

  for file in "${config_files[@]}"; do
    [[ -r "$file" ]] && source "$file"
  done
  unset file
}
