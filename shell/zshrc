##
## Zsh run command configurations (for interactive shell sessions only)
##

# Load source_if_missing utility first
if [[ -f "$DOTFILES_PATH/bin/source_if_missing.sh" ]]; then
  source "$DOTFILES_PATH/bin/source_if_missing.sh"
fi

# Load utilities using source_if_missing
source_if_missing source_files_in "$DOTFILES_PATH/bin/source_files_in.sh"

# Load shell configuration
source "$SHELL_PATH/options"
source "$SHELL_PATH/aliases"
source "$SHELL_PATH/prompts"

# Load app aliases
source_files_in "$DOTFILES_PATH/apps/**/aliases"

# Load functions
if [[ -d "$SHELL_PATH/functions" ]]; then
  fpath+="$SHELL_PATH/functions"
  for func in "$SHELL_PATH/functions"/*; do
    [[ -r "$func" ]] && autoload "$(basename "$func")"
  done
  unset func
fi

# Load local customizations
source_files_in "$DOTFILES_PATH/extra/**/*options_local"
source_files_in "$DOTFILES_PATH/extra/**/*zshrc*"
source_files_in "$DOTFILES_PATH/extra/**/*aliases*"
source_files_in "$DOTFILES_PATH/extra/**/*functions*"
source_files_in "$DOTFILES_PATH/extra/**/*prompt*"
